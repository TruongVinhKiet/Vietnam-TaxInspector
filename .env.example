# ════════════════════════════════════════════════════════════════
#  TaxInspector – Environment Configuration Template
# ════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit the actual .env file to version control!
# ════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ─────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=TaxInspector
DB_EXTERNAL_PORT=5433

# ─── Security ──────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_64_char_hex_string
ENCRYPTION_KEY=change_this_to_another_random_64_char_hex_string
REDIS_PASSWORD=taxinspector_redis_2026_change_me

# ─── Service Ports ─────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
REDIS_EXTERNAL_PORT=6379
KAFKA_EXTERNAL_PORT=9092

# ─── AI / LLM (Optional) ──────────────────────────────────────
# GOOGLE_API_KEY=your_gemini_api_key_here
